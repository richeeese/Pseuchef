namespace Pseuchef.Models
{
    public class UserProfile
    {
        private string username;
        private List<DietaryRestriction> dietaryPref;
        private List<string> excludedIngredients;
        private double calorieGoal;
        private bool isMetric;

        public UserProfile(string username, List<DietaryRestriction> dietaryPref, List<string> excludedIngredients, double calorieGoal, bool isMetric)
        {
            this.username = username;
            this.dietaryPref = new List<DietaryRestriction>();
            this.excludedIngredients = excludedIngredients;
            this.calorieGoal = calorieGoal;
            this.isMetric = isMetric;
        }

        public void AddPreference(DietaryRestriction restriction)
        {
            if (!dietaryPref.Contains(restriction))
            {
                this.dietaryPref.Add(restriction);
            }
        }

        public bool CheckSafety(FoodItem item)
        {
            return !excludedIngredients.Any(ex => ex.Equals(item.ItemName, StringComparison.OrdinalIgnoreCase));
        }

