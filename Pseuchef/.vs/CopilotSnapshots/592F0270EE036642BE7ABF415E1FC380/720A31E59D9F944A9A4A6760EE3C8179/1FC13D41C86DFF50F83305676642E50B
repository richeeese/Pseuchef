using System;
using System.Collections.Generic;
using Pseuchef.Models;

namespace Pseuchef.Interfaces
{
    /// <summary>
    /// Strategy interface for filtering recipes based on different criteria.
    /// </summary>
    public interface IRecipeFilterStrategy
    {
        /// <summary>
        /// Filters a list of recipes based on the strategy's criteria.
        /// </summary>
        /// <param name="recipes">The list of recipes to filter</param>
        /// <returns>A filtered list of recipes</returns>
        List<Recipe> Filter(List<Recipe> recipes);

        /// <summary>
        /// Gets a description of what this filter does.
        /// </summary>
        string GetDescription();
    }
}
