using System;

namespace Pseuchef.Models
{
    /// <summary>
    /// Represents an ingredient in a recipe with tracking metadata.
    /// </summary>
    public class RecipeIngredient
    {
        public string ingredientName { get; private set; }
        public int usedCount { get; private set; }
        public int missedCount { get; private set; }

        /// <summary>
        /// Creates a new recipe ingredient with tracking metadata.
        /// </summary>
        /// <param name="ingredientName">The name of the ingredient</param>
        /// <param name="usedCount">Number of times this ingredient was successfully used</param>
        /// <param name="missedCount">Number of times this ingredient was missed/unavailable</param>
        public RecipeIngredient(string ingredientName, int usedCount = 0, int missedCount = 0)
        {
            if (string.IsNullOrWhiteSpace(ingredientName))
                throw new ArgumentException("Ingredient name cannot be empty", nameof(ingredientName));
            if (usedCount < 0)
                throw new ArgumentException("Used count cannot be negative", nameof(usedCount));
            if (missedCount < 0)
                throw new ArgumentException("Missed count cannot be negative", nameof(missedCount));

            this.ingredientName = ingredientName;
            this.usedCount = usedCount;
            this.missedCount = missedCount;
        }

        /// <summary>
        /// Gets the total count of uses and misses for this ingredient.
        /// </summary>
        public int GetTotalCount() => usedCount + missedCount;

        /// <summary>
        /// Gets the success rate of this ingredient as a percentage (0-100).
        /// </summary>
        public double GetSuccessRate()
        {
            int total = GetTotalCount();
            if (total == 0)
                return 0;
            return (double)usedCount / total * 100;
        }

        /// <summary>
        /// Increments the used count for this ingredient.
        /// </summary>
        public void IncrementUsedCount()
        {
            usedCount++;
        }

        /// <summary>
        /// Increments the missed count for this ingredient.
        /// </summary>
        public void IncrementMissedCount()
        {
            missedCount++;
        }

        /// <summary>
        /// Creates a clone of this recipe ingredient.
        /// </summary>
        public RecipeIngredient Clone()
        {
            return new RecipeIngredient(ingredientName, usedCount, missedCount);
        }

        public override string ToString()
        {
            return $"{ingredientName} (Used: {usedCount}, Missed: {missedCount}, Success Rate: {GetSuccessRate():F1}%)";
        }
    }
}
