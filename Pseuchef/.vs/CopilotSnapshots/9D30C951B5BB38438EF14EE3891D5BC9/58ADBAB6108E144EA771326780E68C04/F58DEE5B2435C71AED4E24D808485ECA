// USAGE EXAMPLE: Enhanced Recipe Class with RecipeIngredient Metadata
//
// This document shows how to use the enhanced Recipe class with ingredient
// tracking metadata (imageUrl, usedCount, missedCount)

using System;
using System.Collections.Generic;
using Pseuchef.Models;

// ============================================================================
// EXAMPLE 1: Creating a Recipe with Ingredients Metadata
// ============================================================================

// Create individual recipe ingredients with metadata
var tomatoIngredient = new RecipeIngredient(
    ingredientName: "Tomato",
    imageUrl: "https://example.com/images/tomato.jpg",
    usedCount: 5,
    missedCount: 2
);

var basilIngredient = new RecipeIngredient(
    ingredientName: "Basil",
    imageUrl: "https://example.com/images/basil.jpg",
    usedCount: 8,
    missedCount: 0
);

var mozzarellaIngredient = new RecipeIngredient(
    ingredientName: "Mozzarella Cheese",
    imageUrl: "https://example.com/images/mozzarella.jpg",
    usedCount: 3,
    missedCount: 1
);

// Create the recipe with the ingredient list
var ingredients = new List<RecipeIngredient> 
{ 
    tomatoIngredient, 
    basilIngredient, 
    mozzarellaIngredient 
};

var margheritaRecipe = new Recipe(
    title: "Margherita Pizza",
    ingredients: ingredients,
    time: 30
);

// ============================================================================
// EXAMPLE 2: Displaying Recipe with Ingredient Metadata
// ============================================================================

// Display the recipe (now includes ingredient metadata)
Console.WriteLine(margheritaRecipe.DisplayRecipe());

// Output will show:
// ========================================
// Recipe: Margherita Pizza
// ========================================
// Preparation Time: 30 minutes
// Number of Ingredients: 3
//
// Ingredients:
//   1. Tomato
//      Image: https://example.com/images/tomato.jpg
//      Used: 5, Missed: 2
//   2. Basil
//      Image: https://example.com/images/basil.jpg
//      Used: 8, Missed: 0
//   3. Mozzarella Cheese
//      Image: https://example.com/images/mozzarella.jpg
//      Used: 3, Missed: 1
// ========================================

// ============================================================================
// EXAMPLE 3: Accessing Individual Ingredient Properties for Frontend
// ============================================================================

var ingredients = margheritaRecipe.GetIngredients();

foreach (var ingredient in ingredients)
{
    // Display ingredient card in frontend
    Console.WriteLine($"Ingredient: {ingredient.ingredientName}");
    Console.WriteLine($"Image: {ingredient.imageUrl}");
    Console.WriteLine($"Used Count: {ingredient.usedCount}");
    Console.WriteLine($"Missed Count: {ingredient.missedCount}");
    Console.WriteLine($"Success Rate: {ingredient.GetSuccessRate():F1}%");
    Console.WriteLine($"Total Uses: {ingredient.GetTotalCount()}");
    Console.WriteLine();
}

// ============================================================================
// EXAMPLE 4: Tracking Ingredient Success/Failure
// ============================================================================

// When a recipe is successfully prepared with an ingredient
tomatoIngredient.IncrementUsedCount();

// When an ingredient is missing from the fridge
tomatoIngredient.IncrementMissedCount();

// Get success metrics
Console.WriteLine(tomatoIngredient.GetSuccessRate()); // Success rate as percentage (0-100)

// ============================================================================
// EXAMPLE 5: Generating Shopping List (works with new ingredient structure)
// ============================================================================

var virtualFridge = new VirtualFridge(); // Your fridge inventory

// Generate shopping list
var shoppingList = margheritaRecipe.GenerateShoppingList(virtualFridge);

// Export to file
var manager = new ShoppingListManager();
manager.ExportToText(shoppingList, "shopping_list.txt");

// ============================================================================
// EXAMPLE 6: Creating Recipe Ingredients with Minimal Data
// ============================================================================

// You can create ingredients with just the name (other fields are optional)
var simpleIngredient = new RecipeIngredient(ingredientName: "Salt");
// imageUrl defaults to ""
// usedCount defaults to 0
// missedCount defaults to 0

